<Window x:Class="Presentation.PaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thanh toán" Height="250" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Thanh toán cho Booking" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Tổng tiền:" Width="100"/>
            <TextBlock x:Name="txtTotal" FontWeight="Bold" Foreground="#10B981"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Phương thức:" Width="100" VerticalAlignment="Center"/>
            <ComboBox x:Name="cboMethod" Width="150" Height="25">
                <ComboBoxItem Content="Card" IsSelected="True"/>
                <ComboBoxItem Content="Transfer"/>
                <ComboBoxItem Content="Cash"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Hủy" Width="70" Height="25" Margin="0,0,10,0" Click="btnCancel_Click"/>
            <Button Content="Xác nhận" Width="70" Height="25" Background="#10B981" Foreground="White" BorderThickness="0" Click="btnConfirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
