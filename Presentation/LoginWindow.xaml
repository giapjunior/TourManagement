<Window x:Class="Presentation.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tour Management - Đăng Nhập" Height="459" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Background="#F0F4F8">
        <Border Background="White" CornerRadius="12" Margin="40,10,40,10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.15" Color="Black"/>
            </Border.Effect>
            <StackPanel Margin="36" VerticalAlignment="Center">

                <TextBlock Text="🌍 Tour Management" FontSize="22" FontWeight="Bold"
                           Foreground="#2563EB" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Đăng nhập để tiếp tục" FontSize="13" Foreground="#6B7280"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <TextBlock Text="Tên đăng nhập" FontSize="13" Foreground="#374151" Margin="0,0,0,6"/>
                <TextBox x:Name="txtUsername" Height="38" FontSize="13"
                         Padding="10,8" BorderBrush="#D1D5DB" BorderThickness="1"
                         Background="#F9FAFB"/>

                <TextBlock Text="Mật khẩu" FontSize="13" Foreground="#374151" Margin="0,16,0,6"/>
                <PasswordBox x:Name="txtPassword" Height="38" FontSize="13"
                             Padding="10,8" BorderBrush="#D1D5DB" BorderThickness="1"
                             Background="#F9FAFB"/>

                <TextBlock x:Name="txtError" Foreground="#EF4444" FontSize="12"
                           Margin="0,10,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>

                <!-- Nút Đăng Nhập -->
                <Button x:Name="btnLogin" Content="Đăng Nhập" Height="42" Margin="0,20,0,0"
                        FontSize="14" FontWeight="SemiBold" Cursor="Hand" Click="btnLogin_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder" Background="#2563EB" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  TextBlock.Foreground="White"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Link Đăng ký -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <TextBlock Text="Chưa có tài khoản? " FontSize="12" Foreground="#6B7280"
                               VerticalAlignment="Center"/>
                    <Button x:Name="btnRegister" Content="Đăng ký ngay" FontSize="12"
                            Foreground="#2563EB" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="btnRegister_Click" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{TemplateBinding Content}" Foreground="#2563EB"
                                           FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                           TextDecorations="Underline"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>
