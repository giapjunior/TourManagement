<Page x:Class="Presentation.BookTourPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Đặt Tour" Background="#F8FAFC">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Danh sách lịch trình & Thông tin Tour -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Thông tin Tour &amp; Lịch trình" FontSize="20" FontWeight="Bold"
                       Foreground="#064E3B" Margin="0,0,0,16"/>
            
            <Border Grid.Row="1" x:Name="pnlTourInfo" Background="White" BorderBrush="#E5E7EB" BorderThickness="1"
                    CornerRadius="8" Padding="16" Margin="0,0,0,16" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="txtTourName" FontSize="18" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="📍 Điểm đến:" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,5,0"/>
                        <TextBlock x:Name="txtTourDestination" Foreground="#374151"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="💰 Giá cơ bản:" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,5,0"/>
                        <TextBlock x:Name="txtTourPrice" Foreground="#059669" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock Text="Mô tả:" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtTourDescription" Foreground="#4B5563" TextWrapping="Wrap" MaxHeight="60" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="2" x:Name="txtNoScheduleMsg" Text="Hiện chưa có lịch trình nào khả dụng cho Tour này." 
                       FontSize="14" Foreground="#EF4444" FontStyle="Italic" Margin="0,0,0,16" Visibility="Collapsed"/>
            <DataGrid CanUserReorderColumns="False" Grid.Row="3" x:Name="dgSchedule" AutoGenerateColumns="False"
                      IsReadOnly="True" SelectionMode="Single" Background="White"
                      BorderBrush="#E5E7EB" GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F9FAFB" FontSize="13"
                      SelectionChanged="dgSchedule_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tour" Binding="{Binding Tour.TourName}" Width="160"/>
                    <DataGridTextColumn Header="Điểm đến" Binding="{Binding Tour.Destination}" Width="120"/>
                    <DataGridTextColumn Header="Ngày đi" Binding="{Binding DepartureDate}" Width="100"/>
                    <DataGridTextColumn Header="Ngày về" Binding="{Binding ReturnDate}" Width="100"/>
                    <DataGridTextColumn Header="Chỗ trống" Binding="{Binding AvailableSlot}" Width="80"/>
                    <DataGridTextColumn Header="Giá/người" Binding="{Binding Tour.Price, StringFormat={}{0:N0}}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Form đặt tour -->
        <Border Grid.Column="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="1"
                CornerRadius="8" Padding="20" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Đặt Tour" FontSize="18" FontWeight="Bold"
                           Foreground="#064E3B" Margin="0,0,0,20"/>

                <TextBlock Text="Tour đã chọn:" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtSelectedTour" Text="(Chọn lịch trình)" FontSize="13"
                           Foreground="#1F2937" FontWeight="SemiBold" Margin="0,0,0,16" TextWrapping="Wrap"/>

                <TextBlock Text="Số người *" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
                <TextBox x:Name="txtPeople" Height="34" Padding="8,6" FontSize="13"
                         BorderBrush="#D1D5DB" Margin="0,0,0,4" Text="1" TextChanged="txtPeople_TextChanged"/>

                <TextBlock x:Name="txtTotal" Text="Tổng tiền: 0 VNĐ" FontSize="13"
                           Foreground="#059669" FontWeight="SemiBold" Margin="0,0,0,20"/>

                <Button Content="🎫 Đặt Tour" Height="42"
                        Background="#064E3B" Foreground="White" BorderThickness="0"
                        FontSize="14" FontWeight="SemiBold" Cursor="Hand" Click="btnBook_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
