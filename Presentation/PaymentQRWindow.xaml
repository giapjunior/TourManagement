<Window x:Class="Presentation.PaymentQRWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cổng thanh toán" Height="480" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid Margin="24">
        <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="Quét mã QR để thanh toán" FontSize="18" FontWeight="Bold" Foreground="#1E3A5F" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock x:Name="txtAmount" Text="Số tiền: 0 VNĐ" FontSize="16" Foreground="#DC2626" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,24"/>
            
            <Border Width="200" Height="200" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12">
                <!-- Giả lập mã QR bằng ký tự -->
                <TextBlock Text="📱&#x0a;[ QR CODE ]" FontSize="24" TextAlignment="Center" Foreground="#9CA3AF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            
            <TextBlock Text="Vui lòng dùng ứng dụng ngân hàng hoặc ví điện tử để quét mã này." TextWrapping="Wrap" TextAlignment="Center" FontSize="13" Foreground="#6B7280" Margin="0,24,0,24" MaxWidth="280"/>
            
            <Button Content="✅ Tôi đã quét mã và thanh toán" Height="44" Width="280" Background="#10B981" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="SemiBold" Cursor="Hand" Click="btnConfirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
