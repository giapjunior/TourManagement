<Page x:Class="Presentation.TourPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Quản lý Tour" Background="#F8FAFC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Quản lý Tour" FontSize="22" FontWeight="Bold"
                   Foreground="#1E3A5F" Margin="0,0,0,16"/>

        <!-- Search + Sort + Add -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtSearch" Grid.Column="0" Height="36" Padding="10,6"
                     FontSize="13" BorderBrush="#D1D5DB" Margin="0,0,8,0"
                     Text="" KeyUp="txtSearch_KeyUp"/>
            <ComboBox x:Name="cboSort" Grid.Column="1" Height="36" Width="160"
                      FontSize="13" BorderBrush="#D1D5DB" Margin="0,0,8,0"
                      SelectionChanged="cboSort_Changed">
                <ComboBoxItem Content="Mặc định" IsSelected="True"/>
                <ComboBoxItem Content="Giá tăng dần"/>
                <ComboBoxItem Content="Giá giảm dần"/>
                <ComboBoxItem Content="Tên A → Z"/>
                <ComboBoxItem Content="Tên Z → A"/>
            </ComboBox>
            <Button Grid.Column="2" Content="🔍 Tìm kiếm" Height="36" Padding="14,0"
                    Background="#6B7280" Foreground="White" BorderThickness="0"
                    FontSize="13" Cursor="Hand" Click="btnSearch_Click" Margin="0,0,8,0"/>
            <Button Grid.Column="3" Content="+ Thêm Tour" Height="36" Padding="14,0"
                    Background="#2563EB" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold" Cursor="Hand" Click="btnAdd_Click"/>
        </Grid>

        <!-- DataGrid -->
        <DataGrid CanUserReorderColumns="False" Grid.Row="2" x:Name="dgTour" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single"
                  Background="White" BorderBrush="#E5E7EB" GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F9FAFB" FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding TourId}" Width="60"/>
                <DataGridTextColumn Header="Tên Tour" Binding="{Binding TourName}" Width="200"/>
                <DataGridTextColumn Header="Điểm đến" Binding="{Binding Destination}" Width="150"/>
                <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat={}{0:N0} VNĐ}" Width="130"/>
                <DataGridTextColumn Header="Số chỗ tối đa" Binding="{Binding MaxSlot}" Width="110"/>
                <DataGridTemplateColumn Header="Trạng thái" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding IsActive}" Foreground="{Binding IsActive, Converter={x:Null}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Text" Value="Hoạt động"/>
                                                <Setter Property="Foreground" Value="#10B981"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                <Setter Property="Text" Value="Ngừng"/>
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Thao tác" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Sửa" Width="60" Height="26" Margin="0,0,6,0"
                                        Background="#F59E0B" Foreground="White" BorderThickness="0"
                                        FontSize="12" Cursor="Hand"
                                        Click="btnEdit_Click" Tag="{Binding TourId}"/>
                                <Button Content="Ẩn" Width="60" Height="26"
                                        Background="#EF4444" Foreground="White" BorderThickness="0"
                                        FontSize="12" Cursor="Hand"
                                        Click="btnDelete_Click" Tag="{Binding TourId}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
