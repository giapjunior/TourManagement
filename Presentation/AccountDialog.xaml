<Window x:Class="Presentation.AccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tài khoản" Height="340" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTitle" Grid.Row="0" Text="Thêm Tài khoản" FontSize="18"
                   FontWeight="Bold" Foreground="#1E3A5F" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Username *" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
            <TextBox x:Name="txtUsername" Height="34" Padding="8,6" FontSize="13" BorderBrush="#D1D5DB" Margin="0,0,0,12"/>

            <TextBlock Text="Password *" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
            <PasswordBox x:Name="txtPassword" Height="34" Padding="8,6" FontSize="13" BorderBrush="#D1D5DB" Margin="0,0,0,12"/>

            <TextBlock Text="Role *" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
            <ComboBox x:Name="cboRole" Height="34" FontSize="13" BorderBrush="#D1D5DB" Margin="0,0,0,12">
                <ComboBoxItem Content="Admin"/>
                <ComboBoxItem Content="Customer" IsSelected="True"/>
            </ComboBox>

            <CheckBox x:Name="chkIsActive" Content="Đang hoạt động" FontSize="13" IsChecked="True"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Hủy" Width="80" Height="36" Margin="0,0,10,0"
                    Background="#E5E7EB" BorderThickness="0" FontSize="13" Cursor="Hand" Click="btnCancel_Click"/>
            <Button Content="Lưu" Width="80" Height="36"
                    Background="#2563EB" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold" Cursor="Hand" Click="btnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
