<Window x:Class="Presentation.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tour Management - Admin" Height="680" Width="1100"
        WindowStartupLocation="CenterScreen">

    <!-- Resources PHẢI khai báo trước khi dùng StaticResource -->
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Grid.Column="0" Background="#1E3A5F">
            <TextBlock Text="🌍 Tour Admin" FontSize="16" FontWeight="Bold"
                       Foreground="White" Margin="20,24,20,30" HorizontalAlignment="Center"/>

            <Button x:Name="btnNavTour"      Content="📋  Quản lý Tour"  Style="{StaticResource NavButton}" Click="btnNavTour_Click"/>
            <Button x:Name="btnNavSchedule"  Content="📅  Lịch trình"    Style="{StaticResource NavButton}" Click="btnNavSchedule_Click"/>
            <Button x:Name="btnNavBooking"   Content="🎫  Đặt tour"      Style="{StaticResource NavButton}" Click="btnNavBooking_Click"/>
            <Button x:Name="btnNavCustomer"  Content="👥  Khách hàng"    Style="{StaticResource NavButton}" Click="btnNavCustomer_Click"/>
            <Button x:Name="btnNavAccount"   Content="🔑  Tài khoản"     Style="{StaticResource NavButton}" Click="btnNavAccount_Click"/>
            <Button x:Name="btnNavStats"     Content="📊  Thống kê"      Style="{StaticResource NavButton}" Click="btnNavStats_Click"/>

            <Button Content="🚪  Đăng xuất" Style="{StaticResource NavButton}"
                    Margin="0,140,0,0" Click="btnLogout_Click"/>
        </StackPanel>

        <!-- Content Area -->
        <Grid Grid.Column="1" Background="#F8FAFC">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>
