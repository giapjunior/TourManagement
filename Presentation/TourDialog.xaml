<Window x:Class="Presentation.TourDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tour" Height="460" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTitle" Grid.Row="0" Text="Thêm Tour" FontSize="18"
                   FontWeight="Bold" Foreground="#1E3A5F" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Tên Tour *" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
            <TextBox x:Name="txtTourName" Height="34" Padding="8,6" FontSize="13" BorderBrush="#D1D5DB" Margin="0,0,0,12"/>

            <TextBlock Text="Điểm đến *" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
            <TextBox x:Name="txtDestination" Height="34" Padding="8,6" FontSize="13" BorderBrush="#D1D5DB" Margin="0,0,0,12"/>

            <TextBlock Text="Mô tả" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
            <TextBox x:Name="txtDescription" Height="60" Padding="8,6" FontSize="13" BorderBrush="#D1D5DB"
                     TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Giá (VNĐ) *" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtPrice" Height="34" Padding="8,6" FontSize="13" BorderBrush="#D1D5DB"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Số chỗ tối đa *" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtMaxSlot" Height="34" Padding="8,6" FontSize="13" BorderBrush="#D1D5DB"/>
                </StackPanel>
            </Grid>

            <CheckBox x:Name="chkIsActive" Content="Đang hoạt động" FontSize="13" IsChecked="True"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Hủy" Width="80" Height="36" Margin="0,0,10,0"
                    Background="#E5E7EB" BorderThickness="0" FontSize="13" Cursor="Hand"
                    Click="btnCancel_Click"/>
            <Button x:Name="btnSave" Content="Lưu" Width="80" Height="36"
                    Background="#2563EB" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold" Cursor="Hand" Click="btnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
