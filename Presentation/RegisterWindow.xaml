<Window x:Class="Presentation.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tour Management - Đăng Ký" Height="580" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Background="#F0F4F8">
        <Border Background="White" CornerRadius="12" Margin="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.15" Color="Black"/>
            </Border.Effect>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="32" VerticalAlignment="Center">

                    <TextBlock Text="📝 Đăng ký tài khoản" FontSize="20" FontWeight="Bold"
                               Foreground="#2563EB" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Tạo tài khoản Customer mới" FontSize="12" Foreground="#6B7280"
                               HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <!-- Username -->
                    <TextBlock Text="Tên đăng nhập *" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtUsername" Height="34" FontSize="13" Padding="10,6"
                             BorderBrush="#D1D5DB" Background="#F9FAFB" Margin="0,0,0,10"/>

                    <!-- Password -->
                    <TextBlock Text="Mật khẩu * (tối thiểu 6 ký tự)" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="txtPassword" Height="34" FontSize="13" Padding="10,6"
                                 BorderBrush="#D1D5DB" Background="#F9FAFB" Margin="0,0,0,10"/>

                    <!-- Confirm Password -->
                    <TextBlock Text="Xác nhận mật khẩu *" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="txtConfirmPassword" Height="34" FontSize="13" Padding="10,6"
                                 BorderBrush="#D1D5DB" Background="#F9FAFB" Margin="0,0,0,10"/>

                    <!-- FullName -->
                    <TextBlock Text="Họ tên *" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtFullName" Height="34" FontSize="13" Padding="10,6"
                             BorderBrush="#D1D5DB" Background="#F9FAFB" Margin="0,0,0,10"/>

                    <!-- Phone -->
                    <TextBlock Text="Số điện thoại * (10 chữ số)" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtPhone" Height="34" FontSize="13" Padding="10,6"
                             BorderBrush="#D1D5DB" Background="#F9FAFB" Margin="0,0,0,10"/>

                    <!-- Email -->
                    <TextBlock Text="Email *" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtEmail" Height="34" FontSize="13" Padding="10,6"
                             BorderBrush="#D1D5DB" Background="#F9FAFB" Margin="0,0,0,10"/>

                    <!-- Address -->
                    <TextBlock Text="Địa chỉ" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtAddress" Height="34" FontSize="13" Padding="10,6"
                             BorderBrush="#D1D5DB" Background="#F9FAFB" Margin="0,0,0,10"/>

                    <!-- Error message -->
                    <TextBlock x:Name="txtError" Foreground="#EF4444" FontSize="12"
                               TextWrapping="Wrap" Visibility="Collapsed" Margin="0,0,0,6"/>

                    <!-- Nút Đăng ký -->
                    <Button x:Name="btnRegister" Content="Đăng Ký" Height="42" Margin="0,8,0,0"
                            FontSize="14" FontWeight="SemiBold" Cursor="Hand" Click="btnRegister_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder" Background="#10B981" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextBlock.Foreground="White"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="#059669"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Link quay lại -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <TextBlock Text="Đã có tài khoản? " FontSize="12" Foreground="#6B7280"
                                   VerticalAlignment="Center"/>
                        <Button Content="Đăng nhập" FontSize="12" Cursor="Hand"
                                Click="btnBackToLogin_Click" Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}" Foreground="#2563EB"
                                               FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                               TextDecorations="Underline"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
