<Window x:Class="Presentation.BookingDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chi tiết Booking" Height="480" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Chi tiết Booking" FontSize="18"
                   FontWeight="Bold" Foreground="#1E3A5F" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Thông tin Booking -->
                <TextBlock Text="📋 THÔNG TIN BOOKING" FontSize="13" FontWeight="Bold"
                           Foreground="#2563EB" Margin="0,0,0,8"/>
                <TextBlock x:Name="txtBookingId" FontSize="13" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtBookingDate" FontSize="13" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtNumPeople" FontSize="13" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtTotalPrice" FontSize="13" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtStatus" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtCancelReason" FontSize="13" Foreground="#EF4444"
                           TextWrapping="Wrap" Margin="0,0,0,8" Visibility="Collapsed"/>

                <Separator Margin="0,8"/>

                <!-- Thông tin Khách hàng -->
                <TextBlock Text="👤 KHÁCH HÀNG" FontSize="13" FontWeight="Bold"
                           Foreground="#2563EB" Margin="0,8,0,8"/>
                <TextBlock x:Name="txtCustName" FontSize="13" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtCustPhone" FontSize="13" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtCustEmail" FontSize="13" Margin="0,0,0,4"/>

                <Separator Margin="0,8"/>

                <!-- Thông tin Tour + Lịch trình -->
                <TextBlock Text="🌍 TOUR - LỊCH TRÌNH" FontSize="13" FontWeight="Bold"
                           Foreground="#2563EB" Margin="0,8,0,8"/>
                <TextBlock x:Name="txtTourName" FontSize="13" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtDestination" FontSize="13" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtDeparture" FontSize="13" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtReturn" FontSize="13" Margin="0,0,0,4"/>

                <Separator Margin="0,8"/>

                <!-- Thông tin Thanh toán -->
                <TextBlock Text="💳 THANH TOÁN" FontSize="13" FontWeight="Bold"
                           Foreground="#2563EB" Margin="0,8,0,8"/>
                <TextBlock x:Name="txtPaymentInfo" FontSize="13" Margin="0,0,0,4" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="Đóng" Width="100" Height="36" HorizontalAlignment="Right"
                Margin="0,16,0,0" Background="#E5E7EB" BorderThickness="0"
                FontSize="13" Cursor="Hand" Click="btnClose_Click"/>
    </Grid>
</Window>
