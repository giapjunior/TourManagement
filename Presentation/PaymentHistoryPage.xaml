<Page x:Class="Presentation.PaymentHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Lịch sử thanh toán" Background="#F8FAFC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="💳 Lịch sử thanh toán" FontSize="22" FontWeight="Bold"
                   Foreground="#064E3B" Margin="0,0,0,16"/>

        <DataGrid CanUserReorderColumns="False" Grid.Row="1" x:Name="dgPayments" AutoGenerateColumns="False"
                  IsReadOnly="True" Background="White" BorderBrush="#E5E7EB"
                  GridLinesVisibility="Horizontal" AlternatingRowBackground="#F9FAFB" FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã PT" Binding="{Binding PaymentId}" Width="80"/>
                <DataGridTextColumn Header="Ngày thanh toán" Binding="{Binding PaymentDate, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="150"/>
                <DataGridTextColumn Header="Tên Tour" Binding="{Binding Booking.Schedule.Tour.TourName}" Width="250"/>
                <DataGridTextColumn Header="Số tiền" Binding="{Binding Amount, StringFormat={}{0:N0} VNĐ}" Width="150"/>
                <DataGridTextColumn Header="Phương thức" Binding="{Binding PaymentMethod}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
