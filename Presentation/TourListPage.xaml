<Page x:Class="Presentation.TourListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Xem Tour" Background="#F8FAFC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Danh sách Tour" FontSize="22" FontWeight="Bold"
                   Foreground="#064E3B" Margin="0,0,0,16"/>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Margin="0,0,8,0">
                <TextBox x:Name="txtSearch" Height="36" Padding="10,6"
                         FontSize="13" BorderBrush="#D1D5DB" 
                         ToolTip="Tên tour hoặc điểm đến (Enter để tìm)" KeyUp="txtSearch_KeyUp"/>
                <TextBlock Text="Tên tour, điểm đến..." Foreground="#9CA3AF" 
                           IsHitTestVisible="False" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
            <Grid Grid.Column="1" Margin="0,0,8,0">
                <TextBox x:Name="txtMaxPrice" Height="36" Padding="10,6"
                         FontSize="13" BorderBrush="#D1D5DB" 
                         ToolTip="Mức giá tối đa" KeyUp="txtSearch_KeyUp"/>
                <TextBlock Text="Mức giá tối đa..." Foreground="#9CA3AF" 
                           IsHitTestVisible="False" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=txtMaxPrice}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
            <DatePicker x:Name="dpDepartureDate" Grid.Column="2" Height="36" 
                     FontSize="13" BorderBrush="#D1D5DB" Margin="0,0,8,0" 
                     ToolTip="Ngày khởi hành từ"/>
            <Button Grid.Column="3" Content="🔍 Tìm kiếm" Height="36" Padding="14,0"
                    Background="#064E3B" Foreground="White" BorderThickness="0"
                    FontSize="13" Cursor="Hand" Click="btnSearch_Click"/>
        </Grid>

        <DataGrid CanUserReorderColumns="False" Grid.Row="2" x:Name="dgTour" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single" Background="White"
                  BorderBrush="#E5E7EB" GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F9FAFB" FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tên Tour" Binding="{Binding TourName}" Width="200"/>
                <DataGridTextColumn Header="Điểm đến" Binding="{Binding Destination}" Width="150"/>
                <DataGridTextColumn Header="Mô tả" Binding="{Binding Description}" Width="200"/>
                <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat={}{0:N0} VNĐ}" Width="130"/>
                <DataGridTextColumn Header="Số chỗ tối đa" Binding="{Binding MaxSlot}" Width="110"/>
                <DataGridTemplateColumn Header="Thao tác" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Xem Lịch trình &amp; Đặt" Height="26"
                                    Background="#10B981" Foreground="White" BorderThickness="0"
                                    FontSize="11" Cursor="Hand" Click="btnBook_Click" Tag="{Binding TourId}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
