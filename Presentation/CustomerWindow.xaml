<Window x:Class="Presentation.CustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tour Management - Khách hàng" Height="640" Width="980"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="CusNavBtn" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#065F46"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Grid.Column="0" Background="#064E3B">
            <TextBlock Text="🌍 Tour" FontSize="16" FontWeight="Bold"
                       Foreground="White" Margin="20,24,20,8" HorizontalAlignment="Center"/>
            <TextBlock x:Name="txtWelcome" Text="Xin chào!" FontSize="11"
                       Foreground="#A7F3D0" HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <Button Content="🗺️  Xem Tour" Style="{StaticResource CusNavBtn}" Click="btnNavTours_Click"/>
            <Button Content="🎫  Đặt Tour" Style="{StaticResource CusNavBtn}" Click="btnNavBookTour_Click"/>
            <Button Content="📋  Booking của tôi" Style="{StaticResource CusNavBtn}" Click="btnNavMyBookings_Click"/>
            <Button Content="💳  Lịch sử thanh toán" Style="{StaticResource CusNavBtn}" Click="btnNavPaymentHistory_Click"/>
            <Button Content="👤  Hồ sơ của tôi" Style="{StaticResource CusNavBtn}" Click="btnNavProfile_Click"/>

            <Button Content="🚪  Đăng xuất" Style="{StaticResource CusNavBtn}" Margin="0,150,0,0" Click="btnLogout_Click"/>
        </StackPanel>

        <!-- Content -->
        <Grid Grid.Column="1" Background="#F8FAFC">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>
