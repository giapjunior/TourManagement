<Window x:Class="Presentation.CustomerDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chi tiết Khách hàng" Height="520" Width="680"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Chi tiết Khách hàng" FontSize="18"
                   FontWeight="Bold" Foreground="#1E3A5F" Margin="0,0,0,12"/>

        <!-- Thông tin cá nhân -->
        <Border Grid.Row="1" Background="#F0F4F8" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="txtName" Grid.Row="0" Grid.Column="0" FontSize="13" Margin="0,0,0,6"/>
                <TextBlock x:Name="txtPhone" Grid.Row="0" Grid.Column="1" FontSize="13" Margin="0,0,0,6"/>
                <TextBlock x:Name="txtEmail" Grid.Row="1" Grid.Column="0" FontSize="13" Margin="0,0,0,6"/>
                <TextBlock x:Name="txtAddress" Grid.Row="1" Grid.Column="1" FontSize="13" Margin="0,0,0,6"/>
                <TextBlock x:Name="txtAccountStatus" Grid.Row="2" Grid.Column="0" FontSize="13" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- Header lịch sử booking -->
        <TextBlock Grid.Row="2" Text="📋 Lịch sử Booking" FontSize="14" FontWeight="Bold"
                   Foreground="#1E3A5F" Margin="0,0,0,8"/>

        <!-- DataGrid lịch sử booking -->
        <DataGrid Grid.Row="3" x:Name="dgBookings" AutoGenerateColumns="False"
                  IsReadOnly="True" Background="White" BorderBrush="#E5E7EB"
                  GridLinesVisibility="Horizontal" AlternatingRowBackground="#F9FAFB" FontSize="12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding BookingId}" Width="50"/>
                <DataGridTextColumn Header="Tour" Binding="{Binding Schedule.Tour.TourName}" Width="160"/>
                <DataGridTextColumn Header="Ngày đặt" Binding="{Binding BookingDate, StringFormat={}{0:dd/MM/yyyy}}" Width="90"/>
                <DataGridTextColumn Header="Số người" Binding="{Binding NumberOfPeople}" Width="70"/>
                <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TotalPrice, StringFormat={}{0:N0}}" Width="100"/>
                <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="4" Content="Đóng" Width="100" Height="36" HorizontalAlignment="Right"
                Margin="0,16,0,0" Background="#E5E7EB" BorderThickness="0"
                FontSize="13" Cursor="Hand" Click="btnClose_Click"/>
    </Grid>
</Window>
