<Window x:Class="Presentation.CancelReasonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nhập lý do hủy" Height="250" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Nhập lý do hủy booking" FontSize="16"
                   FontWeight="Bold" Foreground="#1E3A5F" Margin="0,0,0,12"/>

        <TextBox x:Name="txtReason" Grid.Row="1" Padding="10,8" FontSize="13"
                 BorderBrush="#D1D5DB" TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Hủy bỏ" Width="80" Height="36" Margin="0,0,10,0"
                    Background="#E5E7EB" BorderThickness="0" FontSize="13" Cursor="Hand"
                    Click="btnCancel_Click"/>
            <Button Content="Xác nhận" Width="100" Height="36"
                    Background="#EF4444" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold" Cursor="Hand" Click="btnConfirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
