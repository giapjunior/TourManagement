<Window x:Class="Presentation.ScheduleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lịch trình" Height="380" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTitle" Grid.Row="0" Text="Thêm Lịch trình" FontSize="18"
                   FontWeight="Bold" Foreground="#1E3A5F" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Tour *" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
            <ComboBox x:Name="cboTour" Height="34" FontSize="13" BorderBrush="#D1D5DB"
                      DisplayMemberPath="TourName" SelectedValuePath="TourId" Margin="0,0,0,12"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Ngày khởi hành *" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
                    <DatePicker x:Name="dpDeparture" Height="34" FontSize="13" BorderBrush="#D1D5DB"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Ngày về *" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
                    <DatePicker x:Name="dpReturn" Height="34" FontSize="13" BorderBrush="#D1D5DB"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Số chỗ trống *" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
            <TextBox x:Name="txtSlot" Height="34" Padding="8,6" FontSize="13" BorderBrush="#D1D5DB" Margin="0,0,0,12"/>

            <TextBlock Text="Trạng thái" FontSize="12" Foreground="#374151" Margin="0,0,0,4"/>
            <ComboBox x:Name="cboStatus" Height="34" FontSize="13" BorderBrush="#D1D5DB">
                <ComboBoxItem Content="Open" IsSelected="True"/>
                <ComboBoxItem Content="Closed"/>
                <ComboBoxItem Content="Cancelled"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Hủy" Width="80" Height="36" Margin="0,0,10,0"
                    Background="#E5E7EB" BorderThickness="0" FontSize="13" Cursor="Hand" Click="btnCancel_Click"/>
            <Button Content="Lưu" Width="80" Height="36"
                    Background="#2563EB" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold" Cursor="Hand" Click="btnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
